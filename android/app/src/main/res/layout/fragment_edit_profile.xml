<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_medium"
    android:background="@color/background">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="@dimen/spacing_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

                <!-- Personal Info Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="@dimen/padding_medium"
                    android:layout_marginBottom="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Information"
                        style="@style/TextStyle.HeadingSmall"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <!-- First Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/first_name"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/firstNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Last Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/last_name"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/lastNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/phone"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/phoneInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="phone"
                            android:maxLength="10" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Address Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="@dimen/padding_medium"
                    android:layout_marginBottom="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address (Optional)"
                        style="@style/TextStyle.HeadingSmall"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <!-- Street -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/street"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/streetInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- City -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/city"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/cityInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Province -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/province"
                        android:layout_marginBottom="@dimen/spacing_12">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/provinceInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Postal Code -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/postal_code">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/postalCodeInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Info Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/primary_light"
                    android:padding="@dimen/padding_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ Note"
                        style="@style/TextStyle.BodySmall"
                        android:textColor="@color/white"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email and NIC cannot be changed. Contact support if needed."
                        style="@style/TextStyle.BodySmall"
                        android:textColor="@color/white" />
                </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:spacing="@dimen/spacing_8">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Save Changes"
            style="@style/ButtonStyle.Primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Cancel"
            style="@style/ButtonStyle.Secondary" />
    </LinearLayout>
</LinearLayout>
