<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:layout_margin="@dimen/spacing_8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <!-- Fine ID and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_12">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/fineIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FIN-001234"
                    style="@style/TextStyle.HeadingSmall" />

                <TextView
                    android:id="@+id/categoryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speeding"
                    style="@style/TextStyle.BodySmall"
                    android:layout_marginTop="@dimen/spacing_4" />
            </LinearLayout>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                style="@style/TextStyle.BodySmall"
                android:textColor="@color/warning"
                android:background="@drawable/rounded_badge"
                android:padding="@dimen/spacing_8" />
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amount:"
            style="@style/TextStyle.BodySmall"
            android:layout_marginBottom="@dimen/spacing_4" />

        <TextView
            android:id="@+id/amountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rs. 2,500.00"
            style="@style/TextStyle.BodyLarge"
            android:textColor="@color/primary"
            android:layout_marginBottom="@dimen/spacing_12" />

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_12">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/licensePlateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ABC 1234"
                style="@style/TextStyle.BodySmall"
                android:layout_marginStart="@dimen/spacing_8" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
