<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_medium"
    android:background="@color/background">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Fine Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="@dimen/padding_medium"
                android:layout_marginBottom="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fine ID"
                    style="@style/TextStyle.BodySmall" />

                <TextView
                    android:id="@+id/fineIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FIN-001234"
                    style="@style/TextStyle.HeadingSmall"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Category"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/categoryText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Speeding"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amount"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/amountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs. 2,500.00"
                            style="@style/TextStyle.BodyMedium"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/statusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            style="@style/TextStyle.BodyMedium"
                            android:textColor="@color/warning" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Fine Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="@dimen/padding_medium"
                android:layout_marginBottom="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Violation Details"
                    style="@style/TextStyle.HeadingSmall"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <!-- Violation Type -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/spacing_12">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Violation Type"
                        style="@style/TextStyle.BodySmall" />

                    <TextView
                        android:id="@+id/violationTypeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exceeding Speed Limit"
                        style="@style/TextStyle.BodyMedium" />
                </LinearLayout>

                <!-- Description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/spacing_12">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        style="@style/TextStyle.BodySmall" />

                    <TextView
                        android:id="@+id/descriptionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vehicle was exceeding the speed limit"
                        style="@style/TextStyle.BodyMedium" />
                </LinearLayout>

                <!-- Dates -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_12">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Issue Date"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/issueDateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 15, 2025"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Due Date"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/dueDateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Feb 15, 2025"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        style="@style/TextStyle.BodySmall" />

                    <TextView
                        android:id="@+id/locationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Main Road, Colombo"
                        style="@style/TextStyle.BodyMedium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Vehicle Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="@dimen/padding_medium"
                android:layout_marginBottom="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Information"
                    style="@style/TextStyle.HeadingSmall"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_12">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="License Plate"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/licenseePlateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ABC 1234"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Type"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/vehicleTypeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Car"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Officer Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="@dimen/padding_medium"
                android:layout_marginBottom="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Officer Details"
                    style="@style/TextStyle.HeadingSmall"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_12">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Officer Name"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/officerNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Officer John"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Station"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/stationText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Main Station"
                            style="@style/TextStyle.BodyMedium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/payButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Pay Fine"
                android:layout_marginBottom="@dimen/spacing_8"
                style="@style/ButtonStyle.Primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/downloadReceiptButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Download Receipt"
                style="@style/ButtonStyle.Secondary" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
