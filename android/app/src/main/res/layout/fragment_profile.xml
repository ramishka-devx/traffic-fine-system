<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_medium"
    android:background="@color/background">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Profile Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="@dimen/padding_medium"
                    android:layout_marginBottom="@dimen/spacing_16"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/initialsText"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:text="AB"
                        android:textSize="32sp"
                        android:textColor="@color/white"
                        android:background="@drawable/avatar_background"
                        android:gravity="center"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <TextView
                        android:id="@+id/nameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Doe"
                        style="@style/TextStyle.HeadingSmall"
                        android:layout_marginBottom="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/emailText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="john@example.com"
                        style="@style/TextStyle.BodySmall" />
                </LinearLayout>

                <!-- Personal Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="@dimen/padding_medium"
                    android:layout_marginBottom="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Information"
                        style="@style/TextStyle.HeadingSmall"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_8">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Phone"
                            style="@style/TextStyle.BodySmall"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/phoneText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="N/A"
                            style="@style/TextStyle.BodySmall" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_8">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NIC"
                            style="@style/TextStyle.BodySmall"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/nicText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="N/A"
                            style="@style/TextStyle.BodySmall" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Address Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="@dimen/padding_medium"
                    android:layout_marginBottom="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        style="@style/TextStyle.HeadingSmall"
                        android:layout_marginBottom="@dimen/spacing_12" />

                    <TextView
                        android:id="@+id/streetText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        style="@style/TextStyle.BodySmall"
                        android:layout_marginBottom="@dimen/spacing_4" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/cityText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="N/A"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/provinceText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="N/A"
                            style="@style/TextStyle.BodySmall" />

                        <TextView
                            android:id="@+id/postalCodeText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="N/A"
                            style="@style/TextStyle.BodySmall" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:spacing="@dimen/spacing_8"
                    android:layout_marginBottom="@dimen/spacing_16">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/editProfileButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="Edit Profile"
                        style="@style/ButtonStyle.Primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/logoutButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="Logout"
                        style="@style/ButtonStyle.Danger" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
